	.application .inquiry_form .form_data .col .input.email .mail1,
	.application .inquiry_form .form_data .col .input.email .mail2 { width: 45.89%; }
	.application .inquiry_form .form_data .col .input.email .mail2 { float: right; }
	.inquiry_form .form_data .col .input .select { display: block; position: relative; width: 100%; margin-top: 10px;}
	.inquiry_form .form_data .col .input > span { position: absolute; top: 3px; left: 50%; margin-left: -6px; font-size: 1.75em; line-height: 1.7em; }
	.simple .inquiry_form .form_data .col input[type="text"].homepage { width: 100%; }
	.inquiry_form .form_data .col .input.email .mail1,
	.inquiry_form .form_data .col .input.email .mail2 { width: 45.89%; }
	.inquiry_form .form_data .col .input.email .mail2 { float: right; }
	.recruitment .inquiry_form .form_data .col .input .select { display: block;
		position: relative;
		width: 100%;
		margin-top: 10px;
	}

	/* QnA */
	.contents_list.qna { margin-top: 0; padding: 60px 0 0; }
	.contents_list.qna .top_cont .top_left { position: relative; top: 0; width: 100%; margin-bottom: 22px;}
	.contents_list.qna .top_left > p { font-size: 1.75em; line-height: 1.7em; }
	.contents_list.qna .top_cont .top_right { position: relative; top: 0; }
	.contents_list.qna .top_cont .top_right .select { width: 34.20138%; /* 197px / 576px */ margin: 0; }
	.contents_list.qna .top_cont .top_right .select button.my_value { width: 100%; }
	.contents_list.qna .top_cont .top_right .search { width: 44.27%; /* 255px / 576px */ padding-right: 31px; }
	.contents_list.qna .top_cont .top_right .search input { width: 94.509%; /* 241px / 255px */ }
	
	.contents_list.qna .bottom_cont { padding-top: 43px; }
	.contents_list.qna .bottom_cont .qna_list { margin-bottom: 31px; font-size: 1.75em; line-height: 1.7em; }
	.contents_list.qna .bottom_cont .qna_list .qna_answer > div .text_box{ display: block; width: 87%; }
	.contents_list.qna .bottom_cont .qna_list .qna_title > div > a { width: 87%; }
	

/*	.paginate_complex a > span.arrow { width: 14px; height: 20px; margin-left: -7px; margin-top: -10px; }
	.paginate_complex a.prev > .arrow { background-position: -97px -35px; }
	.paginate_complex a.next > .arrow { background-position: -115px -35px; }
	.paginate_complex a > span.double_arrow { width: 24px; height: 20px; margin-left: -12px; margin-top: -10px; }
	.paginate_complex a.prev > .double_arrow { background-position: -69px -35px; }
	.paginate_complex a.next > .double_arrow { background-position: -132px -35px; }*/

	/* 뷰페이지 버튼 */
	.contents_list.detail .paginate_complex { display: block; padding-bottom: 60px; }
	.contents_list.detail .paginate_complex .sub_icon { display: none; }
	.contents_list.detail .paginate_complex a { width: 30.2083%; /* 174px / 576px */ margin: 0; padding: 12px 0;  font-size: 2.25em;  line-height: 1.25em; border: 2px solid #d0d0ce; }
	.contents_list.detail .paginate_complex a.next {  padding: 12px 0; }
	.contents_list.detail .paginate_complex a.list_go { margin: 0 1.3%; }
	.contents_list.detail .paginate_complex a:hover,
	.contents_list.detail .paginate_complex a:active { color: #fff; background: #009ac8; border: 2px solid #009ac8; }
}

@media only screen and (-webkit-min-device-pixel-ratio: 1.5),
    only screen and (-o-min-device-pixel-ratio: 3/2),
    only screen and (min--moz-device-pixel-ratio: 1.5),
    only screen and (min-device-pixel-ratio: 1.5) {

	.sub_icon { background-image: url(/share/images/sprites/sub_icon640@2.png); background-repeat:  no-repeat; -webkit-background-size: 250px 100px; }

	.select .ctrl { background: url(/share/images/sprites/sub_icon640@2.png) no-repeat; -webkit-background-size: 250px 100px; background-position: 8px -78px; }
	.contents_list .top_cont .top_right .search a { background: url(/share/images/sprites/sub_icon640@2.png) no-repeat; -webkit-background-size: 250px 100px; background-position: -29px -78px; }
	.bx-wrapper .bx-controls-direction .bx-wrapper .bx-controls-direction > a > span { background: url(/share/images/sprites/sub_icon.png) no-repeat; }
}