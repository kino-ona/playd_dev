/* 640px 사이즈 */
@media all and (max-width: 767px) {
	.sub_section .sectitle { width: 92px; height: 92px; }
	.sub_section .sectitle h2 { padding-top: 31px; font-size: 1.725em;  }
	.sub_section .sectitle.one h2 { padding-top: 38px; }

	.sub_section .contents { padding: 60px 0 80px;}
	.sub_section .contents .sub_title { text-align: left; }
	.sub_section .contents .sub_title .s_t { font-size: 3.5em; line-height: 1.5em;  margin: 0 auto; }
	.sub_section .contents .sub_title .s_txt { margin: 20px auto 0; font-size: 1.75em; line-height: 1.7142857em; }
	.sub_section .cube { width: 30px; height: 30px; }
	.sub_section .cube_text { padding-top: 16px; font-size: 2.25em; line-height: 1.5em; }

	.limit { padding: 0 5%; /* 32px / 640px */ }
	.contents .limit { padding: 0 5%; }
	.product_btn span.arrow { float: none; margin: 32px auto 0; }

	.sub_icon { background: url(/share/images/sprites/sub_icon640.png) no-repeat; }
	.bx-wrapper .bx-controls-direction > a > span { background: url(/share/images/sprites/sub_icon.png) no-repeat; }
	.bx-wrapper .bx-controls-direction > a.bx-prev > span  { background-position: -201px -416px; }
	.bx-wrapper .bx-controls-direction > a.bx-next > span { background-position: -258px -416px;  }

	.select li a { font-size: 1.75em; line-height: 1.2em; }
	.select .ctrl { width: 33px; height: 34px; padding: 0; background: url(/share/images/sprites/sub_icon640.png) no-repeat; background-position: 8px -78px; }
	.select .ctrl img { display: none; }

	.company_news .column_icon	{ background: url(/share/images/sprites/sub_icon.png) no-repeat -19px -447px;}
	.company_news .list_icon { background: url(/share/images/sprites/sub_icon.png) no-repeat -77px -447px;}
	
	.paginate_complex .sub_icon {background: url(/share/images/sprites/sub_icon.png) no-repeat; }
	
	.list_hide { display: block; }

	.sns_share .sub_icon {background: url(/share/images/sprites/sub_icon.png) no-repeat; }
	.sns_share .face {background-position: -21px -330px; 	}
	.sns_share .share { background-position: -77px -330px; }
	
	.f_indicator { display: none; }
	
	/* WORK | AD SERVICE | 광고서비스 */
	.advertising .contents { padding: 60px 0 120px; }

	.advertising2 .contents { padding: 80px 0 24px; }
	
	.advertising_list { padding: 0; }
	.advertising_list .contents { padding: 60px 0 80px; }
	
	.advertising.bg .contents { padding: 40px 0; }

	.step_list { width: 100%; margin: 0;}
	.step_list li { position: relative; overflow: hidden; float: none; width: 100%; margin: 0; padding-bottom: 56px; }
	.step_list li .step_numb { font-size: 1.5em; margin-bottom: 10px; }
	.step_list li .step_box { position: static; float: left; width: 35.416667%; /* 204px / 576px */ margin-right: 6.42361%; /* 37px / 576px */ }
	.step_list li .step_text { float: left; width: 57.9861%; /* 334px / 576px */}
	.step_list li .step_text .step_title { margin: 0 0 22px; font-size: 2.625em;  }
	.step_list li .step_text .step_txt { font-size: 1.75em; line-height: 1.7142857em; }
	.step_list li .step_box .arrow { top: auto; right: 50%; bottom: 25px; width: 16px; height: 10px; margin-right: -8px; margin-top: 0; background-position: 0 0; }
	.step_list li.last { width: 100%;  }
	.step_list li.last .step_box { width: 35.416667%; /* 204px / 576px */   }
	
	.adv_list { width: 100%; margin: 80px auto 0; }
	.adv_list li { width: 50%; /* 288px / 576px */ margin-top: 0; margin-bottom: 60px;}
	.adv_list li.center { margin-left: 0; margin-right: 0; }
	.adv_list li.last { float: none; width: 40.27778%; /* 232px / 576px */ margin: 0 auto; }
	.adv_list li .adv_img { width: 86.805%; /* 250px / 288px */ margin: 0 auto; }
	.adv_list li.last .adv_img { width: 100%; }
	.adv_list .adv_title { margin: 25px 0 12.5px; font-size: 2.625em; line-height: 1em; }
	.adv_list .adv_txt { min-height: inherit; font-size: 1.5em; line-height: 1.5em; height: 18px; }
	
	.advertising_btn { padding-left: 0;}
	.advertising_btn a { margin-top: 12px; margin-left: 42.01389%; /* 242px / 576px */ }
	.advertising_btn a > span { width: 42px; margin: 0; }

	.advertising_btn .btn_txt { float: none; font-size: 4.25em; }

