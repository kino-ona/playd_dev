{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "SCSS Watch",
      "type": "shell",
      "command": "npm run sass:watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "scss",
        "pattern": {
          "regexp": "^Error: (.+)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Compiling",
          "endsPattern": "Compiled|Error"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "SCSS Build",
      "type": "shell",
      "command": "npm run sass:build",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
